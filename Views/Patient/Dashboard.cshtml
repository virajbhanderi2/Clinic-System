@model IEnumerable<FrontendEXAM.Models.Appointment>

@{
    ViewData["Title"] = "My Appointments";
}

<div class="d-flex justify-content-between align-items-center page-title">
    <h3 class="mb-0">My Appointments</h3>
    <a asp-action="Book" class="btn btn-sm btn-primary">+ Book Appointment</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<table class="table table-hover">
    <thead>
        <tr>
            <th>Date</th>
            <th>Time Slot</th>
            <th>Status</th>
            <th>Token</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var apt in Model.OrderByDescending(a => a.AppointmentDate))
            {
                var badgeClass = apt.Status?.ToLower() switch {
                    "done" or "completed" => "badge-done",
                    "cancelled" => "badge-skipped",
                    "in_progress" => "badge-progress",
                    "queued" or "scheduled" => "badge-queued",
                    _ => "badge-waiting"
                };
                <tr>
                    <td>@apt.AppointmentDate</td>
                    <td>@apt.TimeSlot</td>
                    <td><span class="badge @badgeClass">@apt.Status</span></td>
                    <td>
                        @if (apt.QueueEntry != null)
                        {
                            <span class="token-num">#@apt.QueueEntry.TokenNumber</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@apt.Id" class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="5" class="text-center text-muted py-3">No appointments yet.</td></tr>
        }
    </tbody>
</table>
