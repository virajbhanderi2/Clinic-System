@model FrontendEXAM.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="d-flex justify-content-between align-items-center page-title">
    <h3 class="mb-0">Appointment Details</h3>
    <a asp-action="Dashboard" class="btn btn-sm btn-secondary">Back</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}
else if (Model != null && Model.Id > 0)
{
    var badgeClass = Model.Status?.ToLower() switch {
        "done" or "completed" => "badge-done",
        "cancelled" => "badge-skipped",
        "in_progress" => "badge-progress",
        _ => "badge-waiting"
    };

    <div class="row">
        <div class="col-md-5 mb-3">
            <div class="card">
                <div class="card-header card-header-blue">Appointment Info</div>
                <div class="card-body">
                    <p><strong>Date:</strong> @Model.AppointmentDate</p>
                    <p><strong>Time:</strong> @Model.TimeSlot</p>
                    <p><strong>Status:</strong> <span class="badge @badgeClass">@Model.Status</span></p>
                    @if (Model.QueueEntry != null)
                    {
                        <p><strong>Token:</strong> <span class="token-num">#@Model.QueueEntry.TokenNumber</span></p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-3">
            <div class="card">
                <div class="card-header card-header-green">Prescription</div>
                <div class="card-body">
                    @if (Model.Prescription != null)
                    {
                        @if (!string.IsNullOrEmpty(Model.Prescription.Notes))
                        {
                            <p><strong>Notes:</strong> @Model.Prescription.Notes</p>
                        }
                        @if (Model.Prescription.Medicines != null && Model.Prescription.Medicines.Any())
                        {
                            <table class="table table-sm">
                                <thead>
                                    <tr><th>Medicine</th><th>Dosage</th><th>Duration</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var med in Model.Prescription.Medicines)
                                    {
                                        <tr><td>@med.Name</td><td>@med.Dosage</td><td>@med.Duration</td></tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No prescription yet.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 mb-3">
            <div class="card">
                <div class="card-header card-header-purple">Report</div>
                <div class="card-body">
                    @if (Model.Report != null)
                    {
                        <p><strong>Diagnosis:</strong> @Model.Report.Diagnosis</p>
                        @if (!string.IsNullOrEmpty(Model.Report.TestRecommended))
                        {
                            <p><strong>Tests:</strong> @Model.Report.TestRecommended</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Report.Remarks))
                        {
                            <p><strong>Remarks:</strong> @Model.Report.Remarks</p>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No report yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger">Appointment not found.</div>
}
