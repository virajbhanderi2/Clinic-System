@model IEnumerable<FrontendEXAM.Models.Prescription>

@{
    ViewData["Title"] = "My Prescriptions";
}

<div class="d-flex justify-content-between align-items-center page-title">
    <h3 class="mb-0">My Prescriptions</h3>
    <a asp-action="Dashboard" class="btn btn-sm btn-secondary">Back</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model != null && Model.Any())
{
    foreach (var rx in Model)
    {
        <div class="card mb-3">
            <div class="card-header card-header-green d-flex justify-content-between">
                <span>Prescription</span>
                <small>Appointment #@rx.AppointmentId</small>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(rx.Notes))
                {
                    <p><strong>Notes:</strong> @rx.Notes</p>
                }
                @if (rx.Medicines != null && rx.Medicines.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr><th>Medicine</th><th>Dosage</th><th>Duration</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var med in rx.Medicines)
                            {
                                <tr><td>@med.Name</td><td>@med.Dosage</td><td>@med.Duration</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No medicines listed.</p>
                }
            </div>
        </div>
    }
}
else
{
    <p class="text-muted mt-3">No prescriptions yet.</p>
}
