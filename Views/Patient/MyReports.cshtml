@model IEnumerable<FrontendEXAM.Models.Report>

@{
    ViewData["Title"] = "My Reports";
}

<div class="d-flex justify-content-between align-items-center page-title">
    <h3 class="mb-0">My Reports</h3>
    <a asp-action="Dashboard" class="btn btn-sm btn-secondary">Back</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model != null && Model.Any())
{
    foreach (var report in Model)
    {
        <div class="card mb-3">
            <div class="card-header card-header-purple d-flex justify-content-between">
                <span>Report</span>
                <small>Appointment #@report.AppointmentId</small>
            </div>
            <div class="card-body">
                <p><strong>Diagnosis:</strong> @report.Diagnosis</p>
                @if (!string.IsNullOrEmpty(report.TestRecommended))
                {
                    <p><strong>Tests Recommended:</strong> @report.TestRecommended</p>
                }
                @if (!string.IsNullOrEmpty(report.Remarks))
                {
                    <p><strong>Remarks:</strong> @report.Remarks</p>
                }
            </div>
        </div>
    }
}
else
{
    <p class="text-muted mt-3">No reports yet.</p>
}
