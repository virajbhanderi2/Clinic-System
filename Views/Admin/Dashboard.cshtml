@model IEnumerable<FrontendEXAM.Models.User>

@{
    ViewData["Title"] = "Admin Dashboard";
    var clinic = ViewBag.Clinic as FrontendEXAM.Models.Clinic;
}

<h3 class="page-title">Admin Dashboard</h3>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (clinic != null)
{
    <div class="row mb-4">
        <div class="col-md-3 mb-2">
            <div class="stat-card bg-blue">
                <h2>@clinic.UserCount</h2>
                <p>Total Users</p>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="stat-card bg-green">
                <h2>@clinic.PatientCount</h2>
                <p>Patients</p>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="stat-card bg-orange">
                <h2>@clinic.DoctorCount</h2>
                <p>Doctors</p>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="stat-card bg-purple">
                <h2>@clinic.ReceptionistCount</h2>
                <p>Receptionists</p>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header card-header-dark">Clinic: @clinic.Name</div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5>All Users</h5>
    <a asp-action="CreateUser" class="btn btn-sm btn-primary">+ Create User</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var user in Model)
            {
                var badgeClass = user.Role?.ToLower() switch {
                    "admin" => "badge-admin",
                    "doctor" => "badge-doctor",
                    "patient" => "badge-patient",
                    "receptionist" => "badge-receptionist",
                    _ => "bg-secondary"
                };
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td><span class="badge @badgeClass">@user.Role</span></td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="3" class="text-center text-muted py-3">No users found.</td></tr>
        }
    </tbody>
</table>
