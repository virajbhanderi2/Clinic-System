@model FrontendEXAM.Models.AddPrescriptionRequest

@{
    ViewData["Title"] = "Add Prescription";
}

<div class="d-flex justify-content-between align-items-center page-title">
    <h3 class="mb-0">Add Prescription</h3>
    <a asp-action="Dashboard" class="btn btn-sm btn-secondary">Back</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header card-header-green">Prescription Form</div>
            <div class="card-body">
                <form asp-action="AddPrescription" method="post">
                    <input type="hidden" name="id" value="@ViewBag.AppointmentId" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <h5 class="mb-3">Medicines</h5>
                    <div id="medicinesContainer">
                        @if (Model?.Medicines != null && Model.Medicines.Any())
                        {
                            for (int i = 0; i < Model.Medicines.Count; i++)
                            {
                                <div class="medicine-row row mb-2">
                                    <div class="col-md-4">
                                        <input name="Medicines[@i].Name" value="@Model.Medicines[i].Name" class="form-control form-control-sm" placeholder="Name" required />
                                    </div>
                                    <div class="col-md-3">
                                        <input name="Medicines[@i].Dosage" value="@Model.Medicines[i].Dosage" class="form-control form-control-sm" placeholder="Dosage" required />
                                    </div>
                                    <div class="col-md-3">
                                        <input name="Medicines[@i].Duration" value="@Model.Medicines[i].Duration" class="form-control form-control-sm" placeholder="Duration" required />
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-btn">Remove</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <button type="button" id="addMedicineBtn" class="btn btn-sm btn-outline-secondary mb-3">+ Add Medicine</button>

                    <div class="border-top pt-3">
                        <button type="submit" class="btn btn-primary">Save Prescription</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let idx = @(Model?.Medicines?.Count ?? 0)
            $('#addMedicineBtn').click(function () {
                $('#medicinesContainer').append(`
                    <div class="medicine-row row mb-2">
                        <div class="col-md-4">
                            <input name="Medicines[${idx}].Name" class="form-control form-control-sm" placeholder="Name" required />
                        </div>
                        <div class="col-md-3">
                            <input name="Medicines[${idx}].Dosage" class="form-control form-control-sm" placeholder="Dosage" required />
                        </div>
                        <div class="col-md-3">
                            <input name="Medicines[${idx}].Duration" class="form-control form-control-sm" placeholder="Duration" required />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-sm btn-outline-danger remove-btn">Remove</button>
                        </div>
                    </div>`);
                idx++;
            });
            $(document).on('click', '.remove-btn', function () {
                $(this).closest('.medicine-row').remove();
            });
        });
    </script>
}
